  discipline_actions                           discipline_actions[]
  dorm_payment_announcements                   dorm_payment_announcements[]
  events                                       events[]
  files                                        files[]
  groups                                       groups[]
  invoices                                     invoices[]
  leave_requests                               leave_requests[]
  meal_payment_announcements                   meal_payment_announcements[]
  notification_preferences                     notification_preferences[]
  notifications                                notifications[]
  payments_payments_created_by_user_idTousers  payments[]                   @relation("payments_created_by_user_idTousers")
  payments_payments_received_by_user_idTousers payments[]                   @relation("payments_received_by_user_idTousers")
  student_accounts                             student_accounts[]
  student_cohort                               student_cohort[]
  student_group_history                        student_group_history[]
  student_living_history                       student_living_history[]
  student_outcomes                             student_outcomes[]
  student_room_assignments                     student_room_assignments[]
  student_timeline                             student_timeline[]
  students                                     students[]
  timetable                                    timetable[]
  timetable_lessons                            timetable_lessons[]
  user_roles                                   user_roles[]
  users                                        users?                       @relation("usersTousers", fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  other_users                                  users[]                      @relation("usersTousers")
  tenants                                      tenants                      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  violations                                   violations[]

  @@unique([tenant_id, username])
}

model violations {
  id                          BigInt              @id @default(autoincrement())
  tenant_id                   BigInt
  student_id                  BigInt
  rule_code                   String
  description                 String
  severity                    String              @default("LOW") @db.VarChar(10)
  evidence_file_id            BigInt?
  detected_at                 DateTime            @default(now()) @db.Timestamptz(6)
  recorded_by_user_id         BigInt?
  linked_discipline_action_id BigInt?
  files                       files?              @relation(fields: [evidence_file_id], references: [id], onUpdate: NoAction)
  discipline_actions          discipline_actions? @relation(fields: [linked_discipline_action_id], references: [id], onUpdate: NoAction)
  users                       users?              @relation(fields: [recorded_by_user_id], references: [id], onUpdate: NoAction)
  students                    students            @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants                     tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
