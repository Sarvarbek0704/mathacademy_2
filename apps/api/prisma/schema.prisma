generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model academic_years {
  id          BigInt        @id @default(autoincrement())
  tenant_id   BigInt
  name        String
  start_date  DateTime      @db.Date
  end_date    DateTime      @db.Date
  is_current  Boolean       @default(false)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  tenants     tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assessments assessments[]
  groups      groups[]
  timetable   timetable[]

  @@unique([tenant_id, name])
}

model announcements {
  id                 BigInt    @id @default(autoincrement())
  tenant_id          BigInt
  audience           String    @db.VarChar(20)
  title              String
  body               String
  is_published       Boolean   @default(false)
  published_at       DateTime? @db.Timestamptz(6)
  created_by_user_id BigInt?
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  users              users?    @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  tenants            tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model assessment_scores {
  assessment_id      BigInt
  student_id         BigInt
  score              Decimal     @db.Decimal(8, 2)
  teacher_comment    String?
  entered_by_user_id BigInt?
  entered_at         DateTime    @default(now()) @db.Timestamptz(6)
  assessments        assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users?      @relation(fields: [entered_by_user_id], references: [id], onUpdate: NoAction)
  students           students    @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([assessment_id, student_id])
}

model assessments {
  id                        BigInt               @id @default(autoincrement())
  tenant_id                 BigInt
  academic_year_id          BigInt
  group_id                  BigInt
  subject_id                BigInt
  type                      String               @db.VarChar(30)
  title                     String
  max_score                 Decimal              @default(100) @db.Decimal(8, 2)
  weight                    Decimal              @default(1.000) @db.Decimal(6, 3)
  held_at                   DateTime             @db.Timestamptz(6)
  created_by_user_id        BigInt?
  is_published_to_guardians Boolean              @default(false)
  created_at                DateTime             @default(now()) @db.Timestamptz(6)
  assessment_scores         assessment_scores[]
  academic_years            academic_years       @relation(fields: [academic_year_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                     users?               @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  groups                    groups               @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects                  subjects             @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants                   tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  discipline_actions        discipline_actions[]
}

model attendance_marks {
  session_id          BigInt
  student_id          BigInt
  status              String              @db.VarChar(10)
  note                String?
  attendance_sessions attendance_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students            students            @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([session_id, student_id])
}

model attendance_sessions {
  id                 BigInt             @id @default(autoincrement())
  tenant_id          BigInt
  group_id           BigInt
  session_date       DateTime           @db.Date
  type               String             @db.VarChar(20)
  period_no          Int                @default(0) @db.SmallInt
  created_by_user_id BigInt?
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  attendance_marks   attendance_marks[]
  users              users?             @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  groups             groups             @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants            tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([group_id, session_date, type, period_no])
}

model audit_logs {
  id                       BigInt            @id @default(autoincrement())
  tenant_id                BigInt
  actor_type               String            @db.VarChar(20)
  actor_user_id            BigInt?
  actor_student_account_id BigInt?
  action                   String            @default("OTHER") @db.VarChar(20)
  entity_type              String
  entity_id                BigInt?
  before_data              String?
  after_data               String?
  ip_address               String?
  created_at               DateTime          @default(now()) @db.Timestamptz(6)
  student_accounts         student_accounts? @relation(fields: [actor_student_account_id], references: [id], onUpdate: NoAction)
  users                    users?            @relation(fields: [actor_user_id], references: [id], onUpdate: NoAction)
  tenants                  tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model auth_attempts {
  id             BigInt   @id @default(autoincrement())
  tenant_id      BigInt
  account_type   String   @db.VarChar(20)
  username_or_id String
  success        Boolean
  ip_address     String?
  user_agent     String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  tenants        tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model auth_locks {
  id             BigInt   @id @default(autoincrement())
  tenant_id      BigInt
  account_type   String   @db.VarChar(20)
  username_or_id String
  locked_until   DateTime @db.Timestamptz(6)
  reason         String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  tenants        tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, account_type, username_or_id])
}

model auth_sessions {
  id                 BigInt    @id @default(autoincrement())
  tenant_id          BigInt
  account_type       String    @db.VarChar(20)
  user_id            BigInt?
  student_account_id BigInt?
  refresh_token_hash String
  device_info        String?
  ip_address         String?
  expires_at         DateTime  @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  tenants            tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model award_recipients {
  award_id       BigInt
  recipient_type String   @db.VarChar(10)
  student_id     BigInt
  group_id       BigInt
  note           String?
  awards         awards   @relation(fields: [award_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  groups         groups   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students       students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([award_id, recipient_type, student_id, group_id])
}

model awards {
  id                BigInt             @id @default(autoincrement())
  tenant_id         BigInt
  award_type        String             @db.VarChar(20)
  title             String
  description       String?
  value_amount      Decimal?           @db.Decimal(12, 2)
  issued_at         DateTime           @default(now()) @db.Timestamptz(6)
  issued_by_user_id BigInt?
  award_recipients  award_recipients[]
  users             users?             @relation(fields: [issued_by_user_id], references: [id], onUpdate: NoAction)
  tenants           tenants            @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model campuses {
  id         BigInt     @id @default(autoincrement())
  tenant_id  BigInt
  name       String
  address    String?
  lat        Decimal?   @db.Decimal(10, 7)
  lng        Decimal?   @db.Decimal(10, 7)
  is_active  Boolean    @default(true)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  tenants    tenants    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  displays   displays[]
  dorms      dorms[]
  events     events[]
  groups     groups[]
  students   students[]
}

model certificates {
  id         BigInt    @id @default(autoincrement())
  tenant_id  BigInt
  student_id BigInt
  title      String
  subject_id BigInt?
  issuer     String?
  score      String?
  issued_at  DateTime? @db.Date
  file_id    BigInt?
  notes      String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  files      files?    @relation(fields: [file_id], references: [id], onUpdate: NoAction)
  students   students  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects   subjects? @relation(fields: [subject_id], references: [id], onUpdate: NoAction)
  tenants    tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model cohorts {
  id              BigInt           @id @default(autoincrement())
  tenant_id       BigInt
  label           String
  graduation_year Int
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  tenants         tenants          @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_cohort  student_cohort[]

  @@unique([tenant_id, label])
}

model competition_entries {
  id                  BigInt                @id @default(autoincrement())
  competition_id      BigInt
  entry_type          String                @db.VarChar(20)
  student_id          BigInt?
  group_id            BigInt?
  name_display        String
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  competitions        competitions          @relation(fields: [competition_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  groups              groups?               @relation(fields: [group_id], references: [id], onUpdate: NoAction)
  students            students?             @relation(fields: [student_id], references: [id], onUpdate: NoAction)
  competition_results competition_results[]
}

model competition_results {
  competition_id      BigInt
  entry_id            BigInt
  rank                Int
  score               Decimal?            @db.Decimal(12, 2)
  prize               String?
  competitions        competitions        @relation(fields: [competition_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  competition_entries competition_entries @relation(fields: [entry_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([competition_id, entry_id])
}

model competitions {
  id                  BigInt                @id @default(autoincrement())
  tenant_id           BigInt
  title               String
  mode                String                @db.VarChar(20)
  starts_at           DateTime              @db.Timestamptz(6)
  ends_at             DateTime?             @db.Timestamptz(6)
  rules               String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  competition_entries competition_entries[]
  competition_results competition_results[]
  tenants             tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model discipline_actions {
  id                    BigInt       @id @default(autoincrement())
  tenant_id             BigInt
  student_id            BigInt
  action_type           String       @db.VarChar(20)
  reason                String
  issued_by_user_id     BigInt?
  issued_at             DateTime     @default(now()) @db.Timestamptz(6)
  related_assessment_id BigInt?
  is_active             Boolean      @default(true)
  users                 users?       @relation(fields: [issued_by_user_id], references: [id], onUpdate: NoAction)
  assessments           assessments? @relation(fields: [related_assessment_id], references: [id], onUpdate: NoAction)
  students              students     @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants               tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  violations            violations[]
}

model display_items {
  playlist_id       BigInt
  sort_order        Int
  item_type         String            @db.VarChar(20)
  payload           String?
  display_playlists display_playlists @relation(fields: [playlist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([playlist_id, sort_order])
}

model display_playlists {
  id            BigInt          @id @default(autoincrement())
  tenant_id     BigInt
  display_id    BigInt
  name          String
  is_default    Boolean         @default(false)
  display_items display_items[]
  displays      displays        @relation(fields: [display_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model displays {
  id                BigInt              @id @default(autoincrement())
  tenant_id         BigInt
  campus_id         BigInt?
  name              String
  location_desc     String?
  is_active         Boolean             @default(true)
  display_playlists display_playlists[]
  campuses          campuses?           @relation(fields: [campus_id], references: [id], onUpdate: NoAction)
  tenants           tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model dorm_announcement_prices {
  dorm_announcement_id       BigInt
  living_type_id             BigInt
  price_amount               Decimal                    @db.Decimal(12, 2)
  currency                   String                     @default("UZS")
  dorm_payment_announcements dorm_payment_announcements @relation(fields: [dorm_announcement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  living_types               living_types               @relation(fields: [living_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([dorm_announcement_id, living_type_id])
}

model dorm_billing_months {
  id                         BigInt                       @id @default(autoincrement())
  tenant_id                  BigInt
  month_key                  String
  month_start                DateTime                     @db.Date
  month_end                  DateTime                     @db.Date
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  tenants                    tenants                      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dorm_payment_announcements dorm_payment_announcements[]

  @@unique([tenant_id, month_key])
}

model dorm_payment_announcements {
  id                       BigInt                     @id @default(autoincrement())
  tenant_id                BigInt
  dorm_month_id            BigInt
  title                    String
  message                  String?
  due_date                 DateTime?                  @db.Date
  is_published             Boolean                    @default(false)
  published_at             DateTime?                  @db.Timestamptz(6)
  created_by_user_id       BigInt?
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  dorm_announcement_prices dorm_announcement_prices[]
  users                    users?                     @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  dorm_billing_months      dorm_billing_months        @relation(fields: [dorm_month_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants                  tenants                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dorm_student_charges     dorm_student_charges[]

  @@unique([tenant_id, dorm_month_id])
}

model dorm_rooms {
  id                       BigInt                     @id @default(autoincrement())
  dorm_id                  BigInt
  room_code                String
  capacity                 Int                        @default(1)
  gender_policy            String?
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  dorms                    dorms                      @relation(fields: [dorm_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_room_assignments student_room_assignments[]

  @@unique([dorm_id, room_code])
}

model dorm_student_charges {
  id                         BigInt                     @id @default(autoincrement())
  tenant_id                  BigInt
  dorm_announcement_id       BigInt
  student_id                 BigInt
  living_type_id             BigInt
  amount                     Decimal                    @db.Decimal(12, 2)
  currency                   String                     @default("UZS")
  status                     String                     @default("PENDING")
  invoice_id                 BigInt?
  note                       String?
  created_at                 DateTime                   @default(now()) @db.Timestamptz(6)
  dorm_payment_announcements dorm_payment_announcements @relation(fields: [dorm_announcement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices                   invoices?                  @relation(fields: [invoice_id], references: [id], onUpdate: NoAction)
  living_types               living_types               @relation(fields: [living_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students                   students                   @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants                    tenants                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([dorm_announcement_id, student_id])
}

model dorms {
  id          BigInt       @id @default(autoincrement())
  tenant_id   BigInt
  campus_id   BigInt?
  name        String
  description String?
  is_active   Boolean      @default(true)
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  dorm_rooms  dorm_rooms[]
  campuses    campuses?    @relation(fields: [campus_id], references: [id], onUpdate: NoAction)
  tenants     tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model event_participants {
  event_id   BigInt
  student_id BigInt
  role       String   @default("PARTICIPANT")
  events     events   @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students   students @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([event_id, student_id])
}

model events {
  id                 BigInt               @id @default(autoincrement())
  tenant_id          BigInt
  campus_id          BigInt?
  title              String
  event_type         String               @default("OTHER") @db.VarChar(20)
  starts_at          DateTime             @db.Timestamptz(6)
  ends_at            DateTime?            @db.Timestamptz(6)
  description        String?
  created_by_user_id BigInt?
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  event_participants event_participants[]
  campuses           campuses?            @relation(fields: [campus_id], references: [id], onUpdate: NoAction)
  users              users?               @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  tenants            tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model files {
  id                  BigInt         @id @default(autoincrement())
  tenant_id           BigInt
  owner_type          String
  owner_id            BigInt?
  purpose             String?        @db.VarChar(30)
  file_name           String
  mime_type           String?
  size_bytes          BigInt?
  url                 String
  storage_provider    String         @default("LOCAL") @db.VarChar(20)
  storage_path        String?
  uploaded_by_user_id BigInt?
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  certificates        certificates[]
  tenants             tenants        @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users?         @relation(fields: [uploaded_by_user_id], references: [id], onUpdate: NoAction)
  violations          violations[]

  @@index([tenant_id, owner_type, owner_id, purpose])
}

model grade_snapshot_rows {
  snapshot_id     BigInt
  student_id      BigInt
  total_score     Decimal         @db.Decimal(12, 2)
  rank            Int
  risk_level      String          @default("GREEN") @db.VarChar(10)
  grade_snapshots grade_snapshots @relation(fields: [snapshot_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  students        students        @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([snapshot_id, student_id])
}

model grade_snapshots {
  id                  BigInt                @id @default(autoincrement())
  tenant_id           BigInt
  group_id            BigInt
  period_type         String                @db.VarChar(10)
  period_start        DateTime              @db.Date
  period_end          DateTime              @db.Date
  generated_at        DateTime              @default(now()) @db.Timestamptz(6)
  grade_snapshot_rows grade_snapshot_rows[]
  groups              groups                @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants             tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model group_subjects {
  group_id   BigInt
  subject_id BigInt
  groups     groups   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects   subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([group_id, subject_id])
}

model groups {
  id                    BigInt                  @id @default(autoincrement())
  tenant_id             BigInt
  campus_id             BigInt?
  academic_year_id      BigInt
  track_id              BigInt?
  name                  String
  grade                 Int                     @db.SmallInt
  curator_user_id       BigInt?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  assessments           assessments[]
  attendance_sessions   attendance_sessions[]
  award_recipients      award_recipients[]
  competition_entries   competition_entries[]
  grade_snapshots       grade_snapshots[]
  group_subjects        group_subjects[]
  academic_years        academic_years          @relation(fields: [academic_year_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  campuses              campuses?               @relation(fields: [campus_id], references: [id], onUpdate: NoAction)
  users                 users?                  @relation(fields: [curator_user_id], references: [id], onUpdate: NoAction)
  tenants               tenants                 @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_tracks        student_tracks?         @relation(fields: [track_id], references: [id], onUpdate: NoAction)
  student_group_history student_group_history[]
  students              students[]
  timetable             timetable[]

  @@unique([tenant_id, academic_year_id, name])
}

model invoices {
  id                   BigInt                 @id @default(autoincrement())
  tenant_id            BigInt
  student_id           BigInt
  type                 String                 @db.VarChar(10)
  period_start         DateTime?              @db.Date
  period_end           DateTime?              @db.Date
  amount               Decimal                @db.Decimal(12, 2)
  currency             String                 @default("UZS")
  status               String                 @default("PENDING") @db.VarChar(20)
  due_date             DateTime?              @db.Date
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  created_by_user_id   BigInt?
  dorm_student_charges dorm_student_charges[]
  users                users?                 @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)
  students             students               @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants              tenants                @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  meal_student_charges meal_student_charges[]
  payments             payments[]
}

model leave_requests {
  id                  BigInt    @id @default(autoincrement())
  tenant_id           BigInt
  student_id          BigInt
  requested_by        String    @default("STUDENT_VERBAL") @db.VarChar(20)
  reason              String
  start_at            DateTime  @db.Timestamptz(6)
  end_at              DateTime  @db.Timestamptz(6)
  status              String    @default("PENDING") @db.VarChar(20)
  approved_by_user_id BigInt?
  approved_at         DateTime? @db.Timestamptz(6)
  closed_at           DateTime? @db.Timestamptz(6)
  notes               String?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  users               users?    @relation(fields: [approved_by_user_id], references: [id], onUpdate: NoAction)
